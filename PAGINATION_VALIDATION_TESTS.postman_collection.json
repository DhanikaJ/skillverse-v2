    {
      "name": "Validation Tests - Users",
      "item": [
        {
          "name": "✅ POST User - Valid Data",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fname\": \"John\",\n  \"lname\": \"Doe\",\n  \"email\": \"john.doe@example.com\",\n  \"phone\": \"9876543210\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users"]
            },
            "description": "Create user with valid data - Expected: 200 OK"
          }
        },
        {
          "name": "❌ POST User - fname Too Short",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fname\": \"J\",\n  \"lname\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users"]
            },
            "description": "Expected: 400 Bad Request - fname must be between 2-100 chars"
          }
        },
        {
          "name": "❌ POST User - Invalid Email",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fname\": \"John\",\n  \"lname\": \"Doe\",\n  \"email\": \"invalid-email\",\n  \"phone\": \"123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users"]
            },
            "description": "Expected: 400 Bad Request - Email should be valid"
          }
        },
        {
          "name": "❌ POST User - Phone Too Long",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fname\": \"John\",\n  \"lname\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"123456789012345678901\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users"]
            },
            "description": "Expected: 400 Bad Request - phone must not exceed 20 characters"
          }
        },
        {
          "name": "❌ POST User - Missing fname",
          "request": {
            "method": "POST",
            "header": [
              {"key": "Content-Type", "value": "application/json"}
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fname\": \"\",\n  \"lname\": \"Doe\",\n  \"email\": \"john@example.com\",\n  \"phone\": \"123\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/users",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users"]
            },
            "description": "Expected: 400 Bad Request - First name is required"
          }
        }
      ]
    },
