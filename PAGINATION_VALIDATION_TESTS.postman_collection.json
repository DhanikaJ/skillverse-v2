              "raw": "http://localhost:8080/api/v1/users?page=0&size=10",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "users"],
              "query": [
                {"key": "page", "value": "0"},
                {"key": "size", "value": "10"}
              ]
            },
            "description": "Get first page of users (10 per page)"
          }
        },
