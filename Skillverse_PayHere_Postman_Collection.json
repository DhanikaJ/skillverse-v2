{
  "info": {
    "_postman_id": "skillverse-payments",
    "name": "Skillverse - PayHere Payment Integration",
    "description": "Complete API collection for testing PayHere payment flow integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Payments",
      "item": [
        {
          "name": "1. Initiate Payment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": 1,\n  \"courseId\": 2,\n  \"amount\": 99.99,\n  \"paymentMethod\": \"PayHere\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/payments/initiate",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "payments",
                "initiate"
              ]
            },
            "description": "Initiates a payment - Student clicks Pay button. Creates a PENDING payment record."
          },
          "response": []
        },
        {
          "name": "2. PayHere Webhook - Success",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_id\": \"1234567\",\n  \"order_id\": \"ORDER123\",\n  \"payment_id\": \"1\",\n  \"status_code\": \"2\",\n  \"amount\": 99.99,\n  \"currency\": \"LKR\",\n  \"custom_1\": \"user-ref-123\",\n  \"md5sig\": \"dummy-signature\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/payments/webhook/payhere-detailed",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "payments",
                "webhook",
                "payhere-detailed"
              ]
            },
            "description": "PayHere sends webhook with status_code=2 (SUCCESS). Confirms payment and auto-enrolls student."
          },
          "response": []
        },
        {
          "name": "3. PayHere Webhook - Failed",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant_id\": \"1234567\",\n  \"order_id\": \"ORDER124\",\n  \"payment_id\": \"2\",\n  \"status_code\": \"-1\",\n  \"amount\": 99.99,\n  \"currency\": \"LKR\",\n  \"custom_1\": \"user-ref-124\",\n  \"md5sig\": \"dummy-signature\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/payments/webhook/payhere-detailed",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "8080",
              "path": [
                "api",
                "v1",
                "payments",
                "webhook",
                "payhere-detailed"
              ]
            },
            "description": "PayHere sends webhook with status_code=-1 (FAILED). Payment marked as FAILED."
          },
          "response": []
        },
